{
  "dependencies": {
    "crypto": "^1.0.1",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "node-cron": "^4.2.1",
    "node-pg-migrate": "^8.0.4",
    "nodemailer": "^8.0.5",
    "pg": "^8.20.0"
  },
  "scripts": {
    "build": "tsc",
    "migrate:create": "node-pg-migrate -m migrations create",
    "migrate": "node-pg-migrate -r ts-node/register -m migrations up",
    "start": "npm run build && npm run migrate && node dist/server.js",
    "dev": "npm run migrate && nodemon --watch 'src/**/*.ts' --exec 'ts-node' src/server.ts",
    "test": "vitest run src/test", 
    "test:unit": "vitest run src/test/unit",
    "test:integration": "vitest run src/test/integration"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.2",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}

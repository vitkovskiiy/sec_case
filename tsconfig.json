{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "lib":["ES2022", "DOM"],
    "rootDir": "./src",
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": false,
    "skipLibCheck": true,
  },
  "include": ["src/**/*","tests/**/*"]
}